ENVIRONMENT=production
SECRET_KEY=change-me-to-a-random-string-at-least-32-characters
LOG_LEVEL=INFO
CORS_ORIGINS=https://your-frontend.vercel.app

# Local Postgres or Supabase **pooler** URI (required on Railway — direct db.*.supabase.co is IPv6-only)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/svararx
# DATABASE_POOLER_URL=postgresql://postgres.<project-ref>:pass@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
# SUPABASE_DB_POOLER_HOST=aws-0-ap-south-1.pooler.supabase.com
# SUPABASE_DB_POOLER_PORT=6543
# TLS: require (default, encrypt without chain verification) | verify-full | disable
# DB_SSL_MODE=require
# For verify-full, supply the Supabase CA cert (path or inline PEM):
# DB_SSL_CA_CERT=/app/certs/supabase-ca.crt
# DB_SSL_CA_CERT_PEM=-----BEGIN CERTIFICATE-----\n...
REDIS_URL=redis://default:pass@host:6379/0

SARVAM_API_KEY=
GROQ_API_KEY=

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWKS_JSON=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
